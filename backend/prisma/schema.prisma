generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String
  createdAt    DateTime @default(now())

  @@map("users")
}

model Dumpster {
  id           String    @id @default(uuid())
  serialNumber String    @unique
  color        String
  isRented     Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  rentals      Rental[]

  @@map("dumpsters")
}

model Rental {
  id              String    @id @default(uuid())
  dumpsterId      String
  cep             String
  street          String
  neighborhood    String
  city            String
  startDate       DateTime  @default(now())
  expectedEndDate DateTime?
  endDate         DateTime?
  createdAt       DateTime  @default(now())

  dumpster     Dumpster  @relation(fields: [dumpsterId], references: [id])

  @@map("rentals")
}
